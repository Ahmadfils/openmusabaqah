// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Group {
  id           String        @id @default(cuid())
  name         String        @unique
  description  String?
  participants Participant[]
  questions    Question[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// A Question belongs to a batch (identified by `number`).
// Multiple Questions can share the same `number` within a group — they form a batch.
model Question {
  id          String   @id @default(cuid())
  number      Int      // Batch number (1-30 typically). Multiple questions can share this.
  surah       String
  surahArabic String?
  surahNumber Int
  startAyah   Int?
  endAyah     Int?
  difficulty  String   @default("medium") // easy, medium, hard
  isUsed      Boolean  @default(false)

  groupId String
  group   Group  @relation(fields: [groupId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Participant {
  id         String  @id @default(cuid())
  name       String
  identifier String? @unique // e.g., seat number or registration ID

  groupId String
  group   Group  @relation(fields: [groupId], references: [id])

  score Score?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Score is now both quantitative (points) and qualitative (notes).
model Score {
  id            String      @id @default(cuid())
  participantId String      @unique
  participant   Participant @relation(fields: [participantId], references: [id])

  points Float? // Numeric score
  notes  String? // Free-text judge observations

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Central real-time synchronisation state
model SystemState {
  id                   String   @id @default("default")
  currentGroupId       String?
  currentParticipantId String?  // Judge-activated participant
  currentBatchNumber   Int?     // Batch number chosen by the participant (broadcasted to their screen)
  updatedAt            DateTime @updatedAt
}
